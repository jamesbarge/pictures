# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/scripts/audit/results/
/screenshots/
/test-results/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# macOS Finder duplicates (created by Cmd-D or Save-As-rename collisions).
# The tsconfig excludes `**/* 2.*`, `**/* 3.*`, `**/* 4.*` patterns
# defensively because these have leaked into commits four separate times.
# Gitignoring them at the source prevents recurrence without further bandages.
* [2-9].ts
* [2-9].tsx
* [2-9].d.ts
* [2-9].mts
* [2-9].svelte
* [2-9].js
* [2-9].jsx
* [2-9].mjs
* [2-9].cjs
* [2-9].json
* [2-9].css
* [2-9].md
* [2-9].example

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Playwright MCP screenshots
.playwright-mcp/
.worktrees

# Private documentation (sensitive business docs)
docs/private/
.planning-archive/

# Local development config
.mcp.json
.cursor/
.tessl/
.claude/
tessl.json
.agent/
.agents/
.kiro/
.windsurf/
.trigger/

# Claude Code auto-generated files
.claude-worktrees/
**/CLAUDE.md
!/CLAUDE.md
.tmp-*

# Local docs (not committed)
docs/

# Local-only directories
packages/
Pictures/
scratchpad/

# AutoResearch snapshots (large HTML files)
.autoresearch/

# Debug logs
firebase-debug.log

# PM2 / Bree scheduler runtime logs
logs/

# Data exports
*.xlsx

# /scrape progress stamp + scratch
/tmp/

# Local QA verification screenshots (not for commit)
pr646-*.png
split-header-*.png

# Session scratch / agent handoff notes — never commit
tasks/todo.md
tasks/lessons.md
