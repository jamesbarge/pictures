# PostHog Analytics
PUBLIC_POSTHOG_KEY=phc_your_project_key_here
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Clerk Authentication
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_your_clerk_secret_key_here

# Vite dev proxy target for /api/*. Defaults to http://localhost:3000 (local
# Next.js backend). Set to https://api.pictures.london to use prod data
# without running the backend locally.
API_PROXY_TARGET=http://localhost:3000
